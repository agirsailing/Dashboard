# InfluxDB init
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=agir-admin-password-changeme

# Shared connection (ingester outside Docker: use http://localhost:8086)
INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=agir-dev-token-changeme
